#!/usr/bin/env zsh
# Convert source file video to 720p MP4 with fast compression
if [[ -z "$1" ]]; then
  echo "Usage: tomp4 <input_file>"
  exit 1
fi
out="${1%.*}.mp4"
[[ "$out" == "$1" ]] && out="${1%.*}-converted.mp4"
ffmpeg -i "$1" -vf "scale=-2:720" -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 128k -y "$out"
